VITE_HMR_ENABLED=false
VITE_HMR_HOST=example.com
VITE_HMR_PROTOCOL=wss
VITE_HMR_CLIENT_PORT=443
VITE_ENABLE_DEBUG_LOGS=false

# mistlib-wasm source repo (private) — used by scripts/fetch-mistlib.mjs
# (runs automatically before dev/build; unset = keep the committed vendored build)
MISTLIB_REPO=git@github.com:<org>/<repo>.git
MISTLIB_REF=develop
